      "commandLists": [
        {
          "scopes": ["personal", "team", "groupchat"],
          "commands": [
            {"title": "dashboard", "description": "Show delivery and driver summary"},
            {"title": "list deliveries", "description": "Show open EWM deliveries"},
            {"title": "show drivers", "description": "List registered drivers"},
            {"title": "list assignments", "description": "Show active driver assignments"}
          ]
        }
      ]
    }
